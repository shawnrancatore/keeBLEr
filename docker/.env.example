# keeBLEr Docker configuration
#
# Copy this file to .env and edit:
#   cp .env.example .env

# ---------- Development (self-signed cert) ----------
# Ports for the dev server (default: 8443/8080)
KEEBLER_PORT_HTTPS=8443
KEEBLER_PORT_HTTP=8080

# ---------- Production (Let's Encrypt) ----------
# Set these and run with: docker compose --profile production up -d
#
# Your public domain name (required for production)
# KEEBLER_DOMAIN=keebler.example.com
#
# Email for Let's Encrypt certificate notifications (optional but recommended)
# KEEBLER_EMAIL=you@example.com
